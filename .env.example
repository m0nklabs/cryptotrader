# Example environment file (DO NOT put real secrets here)

# Bitfinex API Credentials
BITFINEX_API_KEY_MAIN=
BITFINEX_API_SECRET_MAIN=
BITFINEX_API_KEY_SUB=
BITFINEX_API_SECRET_SUB=
BITFINEX_API_KEY_TEST=
BITFINEX_API_SECRET_TEST=
BITFINEX_TOTP_SECRET=

# Optional aliases (the Bitfinex REST client will also read these)
BITFINEX_API_KEY=
BITFINEX_API_SECRET=

# API Settings
BITFINEX_TIMEOUT=30
BITFINEX_RATE_LIMIT=90
BITFINEX_ENVIRONMENT=production

# Optional email integration (use app password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Optional database for indicator weights/signals and persistence
# This should be set via GitHub repository secret: DATABASE_URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# Optional local Docker Compose Postgres defaults
# Both cryptotrader_copilot and ../cryptotrader_hermes must use the same values
# so they connect to the shared Postgres container and the same tables.
DB_PORT=50432
DB_DATA_PATH=/home/flip/postgres_data/shared
DB_NAME=cryptotrader_dev
DB_USER=cryptotrader
DB_PASSWORD=cryptotrader

# Local service port matrix (cryptotrader_copilot defaults)
PORT=50000
FRONTEND_PORT=50176
INGESTION_PORT=50100
LEGACY_PORT=50787

# Hermes workspace port matrix (document these in ../cryptotrader_hermes/.env)
# PORT=51000
# FRONTEND_PORT=51176
# INGESTION_PORT=51100
# LEGACY_PORT=51787

# Optional Ollama (LLM) configuration for signals/dossier
OLLAMA_HOST=
OLLAMA_MODEL=
OLLAMA_USER=
OLLAMA_PASSWORD=

# Guardian (llama_cpp_guardian) proxy — REQUIRED for Guardian-backed LLM features
# (GuardianAnalyst, Multi-Brain roles, health checks, /v1/models).
# When absent, Guardian features short-circuit (no unauthenticated polling).
# Set to any non-empty string to enable; value is used as Bearer token.
GUARDIAN_API_KEY=
GUARDIAN_HOST=http://localhost:11434
GUARDIAN_DEFAULT_MODEL=GLM-4.7-Flash

# Optional Multi-Brain AI provider keys (Phase 1+)
# IMPORTANT: do not commit real keys. Use env vars in your runtime or CI secrets.
OPENAI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Optional OpenRouter recommended headers
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=

# Optional dossier debug logging
DOSSIER_DEBUG=false

# Signal Alerts (opt-in, disabled by default)
SIGNAL_ALERTS_ENABLED=false
SIGNAL_WEBHOOK_URL=

# Candle Ingestion
# Standard timeframes: 1m, 5m, 15m, 1h, 4h, 1d
# The multi-timeframe ingestion script uses these by default
TIMEFRAMES=1m,5m,15m,1h,4h,1d
