+       - check-success=Backend (ruff + pytest)
+       - check-success=Pre-commit checks
+@@ -198,8 +200,9 @@ pull_request_rules:
+       - -draft
+       - -label=do-not-merge
+     actions:
+-      merge:
+-        method: squash
++      label:
++        add:
++          - ready-for-manual-merge
+ 
