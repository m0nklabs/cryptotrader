# Docker Compose Environment Variables
# Copy this file to .env and customize for your environment

# PostgreSQL Configuration
# Shared Postgres container for both cryptotrader_copilot and ../cryptotrader_hermes.
# Use the same DB_* values in both workspaces so they hit the same physical database.
DB_PORT=50432
DB_DATA_PATH=/home/flip/postgres_data/shared
DB_NAME=cryptotrader_dev
DB_USER=cryptotrader
DB_PASSWORD=cryptotrader

# Application port matrix (cryptotrader_copilot defaults)
PORT=50000
FRONTEND_PORT=50176
INGESTION_PORT=50100
LEGACY_PORT=50787

# Hermes workspace port matrix (use these in ../cryptotrader_hermes/.env)
# PORT=51000
# FRONTEND_PORT=51176
# INGESTION_PORT=51100
# LEGACY_PORT=51787

# Bitfinex API (optional, for live market data)
BITFINEX_API_KEY=
BITFINEX_API_SECRET=
BITFINEX_TIMEOUT=30
BITFINEX_RATE_LIMIT=90

# Telegram Bot (optional, for notifications)
TELEGRAM_BOT_TOKEN=

# Discord Webhook (optional, for notifications)
DISCORD_WEBHOOK_URL=

# Guardian (llama_cpp_guardian) proxy — REQUIRED for Guardian-backed LLM features
# When absent, Guardian features short-circuit rather than polling unauthenticated.
GUARDIAN_API_KEY=
GUARDIAN_HOST=http://localhost:11434

# Frontend proxy target is derived from PORT in docker-compose.dev.yml.
